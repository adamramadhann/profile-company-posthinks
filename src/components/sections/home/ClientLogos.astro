---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Import all logo images from assets folder using absolute path
const logoModules = import.meta.glob<{ default: ImageMetadata }>("/src/assets/logos/*.png", {
  eager: true,
  import: "default",
});

// Helper function to get logo image by filename
const getLogo = (filename: string) => {
  const key = `/src/assets/logos/${filename}`;
  return logoModules[key];
};

const clientsRow1 = [
  { name: "Pertamina", src: getLogo("pertamina.png") },
  { name: "Samsung", src: getLogo("samsung.png") },
  { name: "Grab", src: getLogo("grab.png") },
  { name: "Prudential", src: getLogo("prudential.png") },
  { name: "Pegadaian", src: getLogo("pegadaian.png") },
  { name: "BCA", src: getLogo("bca.png") },
  { name: "BRI", src: getLogo("bri.png") },
  { name: "Viu", src: getLogo("viu.png") },
  { name: "OCBC", src: getLogo("ocbc.png") },
  { name: "Narasi", src: getLogo("narasi.png") },
  { name: "Ancol", src: getLogo("ancol.png") },
];

const clientsRow2 = [
  { name: "Jasa Marga", src: getLogo("jasa-marga.png") },
  { name: "KOMDIGI", src: getLogo("komdigi.png") },
  { name: "Telkom Indonesia", src: getLogo("telkom.png") },
  { name: "BNI", src: getLogo("bni.png") },
  { name: "Unilever", src: getLogo("unilever.png") },
  { name: "Vivo", src: getLogo("vivo.png") },
  { name: "Suzuki", src: getLogo("suzuki.png") },
  { name: "Shopee", src: getLogo("shopee.png") },
  { name: "Kemenkes", src: getLogo("kemenkes.png") },
  { name: "IM3", src: getLogo("im3.png") },
  { name: "Hello Sehat", src: getLogo("hello-sehat.png") },
];

// Duplikasi untuk efek seamless infinite scroll
const row1 = [...clientsRow1, ...clientsRow1];
const row2 = [...clientsRow2, ...clientsRow2];
---

<section class="py-24 bg-slate-950 overflow-hidden relative">
  <!-- Background Pattern -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute inset-0 bg-dot-grid opacity-[0.02]"></div>
    <div
      class="absolute top-0 right-0 w-[400px] h-[400px] bg-cyan-500/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-teal-500/5 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="container mx-auto px-6 mb-16 text-center relative z-10">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 mb-6"
    >
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
      <span
        class="text-[10px] font-black text-cyan-400 uppercase tracking-[0.3em]"
        >Our Network</span
      >
    </div>
    <h2 class="text-4xl md:text-5xl font-black text-white tracking-tighter">
      Dipercaya oleh <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-teal-400"
        >Brand Ternama</span
      >
    </h2>
  </div>

  <div class="flex flex-col gap-8 md:gap-12 relative">
    <div class="relative flex overflow-hidden group">
      <div
        class="flex animate-marquee-left whitespace-nowrap gap-12 md:gap-20 items-center py-4"
      >
        {
          row1.map((client) => (
            <div class="w-32 md:w-48 flex-shrink-0 flex items-center justify-center grayscale opacity-30 hover:grayscale-0 hover:opacity-100 hover:scale-110 transition-all duration-500 ease-out cursor-pointer">
              <Image
                src={client.src}
                alt={client.name}
                class="max-h-16 md:max-h-16 w-auto object-contain invert brightness-0 hover:invert-0 hover:brightness-100"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>

    <div class="relative flex overflow-hidden group">
      <div
        class="flex animate-marquee-right whitespace-nowrap gap-12 md:gap-20 items-center py-4"
      >
        {
          row2.map((client) => (
            <div class="w-32 md:w-48 flex-shrink-0 flex items-center justify-center grayscale opacity-30 hover:grayscale-0 hover:opacity-100 hover:scale-110 transition-all duration-500 ease-out cursor-pointer">
              <Image
                src={client.src}
                alt={client.name}
                class="max-h-16 md:max-h-16 w-auto object-contain invert brightness-0 hover:invert-0 hover:brightness-100"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="absolute inset-y-0 left-0 w-24 md:w-64 bg-gradient-to-r from-slate-950 via-slate-950/80 to-transparent z-10 pointer-events-none"
    >
    </div>
    <div
      class="absolute inset-y-0 right-0 w-24 md:w-64 bg-gradient-to-l from-slate-950 via-slate-950/80 to-transparent z-10 pointer-events-none"
    >
    </div>
  </div>
</section>

<style>
  /* Animasi ke Kiri */
  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Animasi ke Kanan */
  @keyframes marquee-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .animate-marquee-left {
    animation: marquee-left 50s linear infinite;
  }

  .animate-marquee-right {
    animation: marquee-right 55s linear infinite;
  }

  /* Efek berhenti saat hover pada baris tersebut */
  .group:hover .animate-marquee-left,
  .group:hover .animate-marquee-right {
    animation-play-state: paused;
  }

  /* Responsivitas Kecepatan di Mobile */
  @media (max-width: 768px) {
    .animate-marquee-left {
      animation-duration: 30s;
    }
    .animate-marquee-right {
      animation-duration: 35s;
    }
  }
</style>
